# ── Production ───────────────────────────────────────────────────────────────
# Copy to prod.env ON THE SERVER, fill in the secrets, and keep it out of git.
# Referenced by the systemd unit (EnvironmentFile). This .example is committed;
# prod.env is not.

PORT=8787

# GitHub OAuth app for PRODUCTION (a separate app from the dev one).
# Callback URL on the app must be:
#   https://api.plugins.wago.sh/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Must match the OAuth app's callback URL exactly.
OAUTH_REDIRECT_URL=https://api.plugins.wago.sh/auth/github/callback

# The public site; also the only allowed CORS origin.
FRONTEND_URL=https://plugins.wago.sh

# REQUIRED in prod — a real session dies if this is empty/rotated.
# Generate once and keep it stable:  openssl rand -hex 32
SESSION_SECRET=

# Paths relative to the service's WorkingDirectory (see the systemd unit).
PACKAGES_FILE=./data/packages.json
STORE_FILE=./data/store.json

# https everywhere → Secure cookies.
DEV_MODE=false

# Share the session cookie across plugins.wago.sh (site) and api.plugins.wago.sh (API).
# Both must be sub-domains of this value.
COOKIE_DOMAIN=.wago.sh
