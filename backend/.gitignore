# Registry store — created/seeded at runtime (JSON store file + Pebble DB dir).
# Never commit runtime state; it would clobber the live store on deploy.
data/
/registry.new

# Atomic-write temp files
*.tmp

# Built binaries (anchored so they don't also match the cmd/registry source dir)
/registry
/registry-backend

# Local env (real secrets); the *.env.example templates ARE committed.
.env
dev.env
prod.env
